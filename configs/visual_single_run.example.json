{
  "run_name": "visual_predictive_rnn",
  "output_root": "results",
  "env_id": "B1_l_shape",
  "seed": 7,
  "epochs": 20,
  "sequence_length": 64,
  "train_sequences_per_epoch": 24,
  "val_sequences_per_epoch": 6,
  "batch_size": 4,
  "eval_rollout_steps": 768,
  "replay_steps": 256,
  "gradient_clip": 1.0,
  "checkpoint_every_n_epochs": 5,
  "early_stopping_patience": 8,
  "observation_mode": "visual",
  "include_head_direction": true,
  "dashboard": {
    "enabled": true,
    "backend": "tensorboard",
    "update_every_n_steps": 5,
    "project": "predictive-rnn-visual"
  },
  "tile_map": {
    "tile_size": 0.05,
    "patch_size": 7,
