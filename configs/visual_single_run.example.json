    "amp_dtype": "float16",
    "gradient_checkpointing": true,
    "encoder_type": "cnn",
    "encoder_hidden_size": 256,
    "encoder_output_size": 128,
    "visual_patch_size": 147,
    "visual_patch_width": 7,
    "visual_channels": 3,
    "head_direction_size": 2,
